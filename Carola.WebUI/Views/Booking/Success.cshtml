@{
    ViewData["Title"] = "Rezervasyon Tamamlandı";
    Layout = "~/Views/_MainLayout/Index.cshtml";
}

<style>
    .success-section {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8f9fb;
        padding: 60px 0;
    }

    .success-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.09);
        padding: 60px 50px;
        text-align: center;
        max-width: 540px;
        width: 100%;
    }

    .success-icon {
        width: 90px;
        height: 90px;
        background: linear-gradient(135deg, #0d6efd, #0a58ca);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 28px;
    }

        .success-icon i {
            color: #fff;
            font-size: 40px;
        }

    .success-card h2 {
        font-size: 28px;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 14px;
    }

    .success-card p {
        font-size: 15px;
        color: #777;
        line-height: 1.7;
        margin-bottom: 32px;
    }

    .success-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-primary-custom {
        padding: 12px 28px;
        background: linear-gradient(135deg, #0d6efd, #0a58ca);
        color: #fff;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        transition: opacity 0.2s;
    }

        .btn-primary-custom:hover {
            opacity: 0.88;
            color: #fff;
        }

    .btn-outline-custom {
        padding: 12px 28px;
        border: 1.5px solid #0d6efd;
        color: #0d6efd;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-outline-custom:hover {
            background: #0d6efd;
            color: #fff;
        }
</style>

<section class="success-section">
    <div class="container">
        <div class="d-flex justify-content-center">
            <div class="success-card">
                <div class="success-icon">
                    <i class="fas fa-check"></i>
                </div>
                <h2>Rezervasyonunuz Alındı!</h2>
                <p>
                    Talebiniz başarıyla oluşturuldu. Ekibimiz en kısa sürede
                    sizinle iletişime geçecektir. İyi yolculuklar dileriz!
                </p>
                <div class="success-actions">
                    <a href="/" class="btn-primary-custom">
                        <i class="fas fa-home"></i>&nbsp; Ana Sayfa
                    </a>
                    <a href="/CarList/Index" class="btn-outline-custom">
                        <i class="fas fa-car"></i>&nbsp; Araçlara Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

