@model List<ResultWhyUsDto>

<section class="why-chooseus-section pt_120 pb_90">
    <div class="container">
        <div class="row">
            <div class="col-xl-4 col-lg-4 col-md-12 col-sm-12">
                <div class="section-title mb_60">
                    <span class="sub-title">Neden Carola?</span>
                    <h2 class="title">Kendi sürüş tarzınızla dünyayı keşfedin</h2>
                </div>
            </div>
            @foreach (var item in Model)
            {
                <div class="col-xl-4 col-lg-4 col-md-6 col-sm-12">
                    <div class="why-chooseus-block">
                        <div class="why-chooseus-icon">
                            <i class="@item.IconUrl"></i>
                        </div>
                        <h5 class="why-chooseus-title">@item.Title</h5>
                        <p class="why-chooseus-text">@item.Description</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
