@model List<ResultCategoryDto>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<style>
    /* Section Arkaplanı - Kartların öne çıkması için hafif gri */
    .car-type-section {
        background-color: #f8f9fa;
        padding: 100px 0;
    }

    .section-title h2 {
        font-weight: 800;
        letter-spacing: -1px;
        color: #1a1a1a;
        margin-bottom: 40px;
    }

    /* Kart Tasarımı */
    .car-type-item {
        text-align: center;
        background: #ffffff;
        padding: 30px 20px;
        border-radius: 20px;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        border: 1px solid rgba(0,0,0,0.03);
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        cursor: pointer;
    }

        .car-type-item:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            border-color: #007bff; /* Temanıza göre rengi değiştirebilirsiniz */
        }

    /* Görsel Alanı */
    .car-image {
        width: 100%;
        height: 140px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

        .car-image img {
            max-width: 90%;
            max-height: 100%;
            object-fit: contain; /* Araçların kesilmemesi ve tam görünmesi için en iyisi */
            filter: drop-shadow(0 10px 10px rgba(0,0,0,0.1));
            transition: 0.3s;
        }

    .car-type-item:hover .car-image img {
        transform: scale(1.05);
    }

    /* Yazı Stili */
    .car-name h6 {
        font-size: 18px;
        font-weight: 700;
        color: #2d3436;
        margin: 0;
        transition: 0.3s;
    }

    .car-type-item:hover .car-name h6 {
        color: #007bff;
    }

    /* Swiper Navigasyon Özelleştirme */
    .carTypeSlider {
        padding: 40px 15px !important;
    }

    .swiper-button-next, .swiper-button-prev {
        background: #fff;
        width: 45px;
        height: 45px;
        border-radius: 50%;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        color: #007bff !important;
    }

        .swiper-button-next:after, .swiper-button-prev:after {
            font-size: 18px !important;
            font-weight: bold;
        }

    .swiper-pagination-bullet-active {
        background: #007bff !important;
        width: 25px;
        border-radius: 5px;
    }
</style>

<section class="car-type-section">
    <div class="container">
        <div class="section-title text-center mb-5">
            <span class="sub-title">Araç Türleri</span>
            <h2 class="title">Araç Kategorilerini İnceleyin</h2>
        </div>

        <div class="swiper carTypeSlider">
            <div class="swiper-wrapper">
                @foreach (var item in Model)
                {
                    <div class="swiper-slide">
                        <a href="/CarList/Index?categoryId=@item.CategoryId" style="text-decoration:none;">
                            <div class="car-type-item">
                                <div class="car-image">
                                    <img src="@item.CategoryImage" alt="@item.CategoryName">
                                </div>
                                <div class="car-name">
                                    <h6>@item.CategoryName</h6>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>

            <br /><br /><br />
            <div class="swiper-button-next"></div>
            <div class="swiper-button-prev"></div>
            <div class="swiper-pagination"></div>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
    var swiper = new Swiper(".carTypeSlider", {
        loop: true,
        spaceBetween: 30,
        centeredSlides: false,
        autoplay: {
            delay: 3500,
            disableOnInteraction: false,
        },
        pagination: {
            el: ".swiper-pagination",
            clickable: true,
            dynamicBullets: true,
        },
        navigation: {
            nextEl: ".swiper-button-next",
            prevEl: ".swiper-button-prev",
        },
        breakpoints: {
            0: { slidesPerView: 1.2 },
            576: { slidesPerView: 2 },
            768: { slidesPerView: 3 },
            1024: { slidesPerView: 4 }
        }
    });
</script>