@model CreateGalleryDto
@using Carola.DtoLayer.Dtos.GalleryDtos
@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    :root { --bg-dark:#0d0f14; --bg-dark2:#13161e; --bg-dark3:#1a1e2a; --accent:#e8ff47; --accent-dim:rgba(232,255,71,.12); --danger:#ff5259; --border:rgba(255,255,255,.07); --text:#e2e8f0; --text-muted:#7a8499; --radius:12px; --radius-lg:18px; }
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    .cg-root { padding:28px; font-family:'DM Sans','Segoe UI',sans-serif; color:var(--text); }
    .cg-breadcrumb { display:flex; align-items:center; gap:6px; font-size:12px; color:var(--text-muted); margin-bottom:6px; }
    .cg-breadcrumb a { color:var(--text-muted); text-decoration:none; } .cg-breadcrumb a:hover { color:var(--text); } .cg-breadcrumb span { color:var(--text); }
    .cg-page-header { display:flex; align-items:flex-end; justify-content:space-between; gap:16px; margin-bottom:28px; flex-wrap:wrap; }
    .cg-page-title { font-family:'Syne',Georgia,sans-serif; font-size:26px; font-weight:700; color:var(--text); line-height:1; }
    .cg-page-subtitle { font-size:13px; color:var(--text-muted); margin-top:5px; }
    .btn-accent { background:var(--accent); color:#0d0f14; border:none; border-radius:10px; padding:9px 20px; font-size:13px; font-weight:600; font-family:inherit; cursor:pointer; display:inline-flex; align-items:center; gap:7px; text-decoration:none; transition:opacity .2s; }
    .btn-accent:hover { opacity:.85; color:#0d0f14; }
    .btn-outline { background:transparent; color:var(--text-muted); border:1px solid var(--border); border-radius:10px; padding:9px 18px; font-size:13px; font-weight:500; font-family:inherit; cursor:pointer; display:inline-flex; align-items:center; gap:7px; text-decoration:none; transition:background .2s,color .2s; }
    .btn-outline:hover { background:var(--bg-dark2); color:var(--text); }
    .cg-card { background:var(--bg-dark2); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; margin-bottom:20px; }
    .cg-card-head { display:flex; align-items:center; gap:10px; padding:16px 20px; border-bottom:1px solid var(--border); }
    .cg-card-icon { width:32px; height:32px; border-radius:9px; display:grid; place-items:center; font-size:15px; background:var(--accent-dim); color:var(--accent); }
    .cg-card-title { font-size:14px; font-weight:600; color:var(--text); }
    .cg-card-subtitle { font-size:12px; color:var(--text-muted); margin-top:1px; }
    .cg-card-body { padding:20px; }
    .cg-field { display:flex; flex-direction:column; gap:6px; margin-bottom:18px; }
    .cg-field:last-child { margin-bottom:0; }
    .cg-field label { font-size:12px; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:.6px; }
    .cg-required { color:var(--danger); margin-left:3px; }
    .cg-field input { background:var(--bg-dark3); border:1px solid var(--border); border-radius:10px; color:var(--text); padding:10px 14px; font-size:13px; font-family:inherit; outline:none; width:100%; transition:border .2s,box-shadow .2s; }
    .cg-field input::placeholder { color:var(--text-muted); }
    .cg-field input:focus { border-color:var(--accent); box-shadow:0 0 0 3px var(--accent-dim); }
    .field-validation-error { font-size:11px; color:var(--danger); }
    .input-validation-error { border-color:rgba(255,82,89,.5) !important; box-shadow:0 0 0 3px rgba(255,82,89,.1) !important; }
    .cg-action-bar { display:flex; align-items:center; justify-content:flex-end; gap:10px; padding-top:20px; border-top:1px solid var(--border); margin-top:4px; }
    .cg-img-preview { width:100%; height:180px; border-radius:10px; background:var(--bg-dark3); border:1px dashed var(--border); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; overflow:hidden; margin-top:10px; }
    .cg-img-preview img { width:100%; height:100%; object-fit:cover; display:none; }
    .cg-img-preview.has-img img { display:block; }
    .cg-img-preview.has-img .cg-preview-ph { display:none; }
    .cg-preview-ph { display:flex; flex-direction:column; align-items:center; gap:6px; }
    .cg-preview-icon { font-size:28px; color:var(--text-muted); }
    .cg-preview-label { font-size:11px; color:var(--text-muted); }
</style>

<div class="cg-root">
    <div class="cg-breadcrumb">
        İçerik Yönetimi <span>›</span>
        <a href="/Admin/Gallery/GalleryList/">Galeri Listesi</a>
        <span>›</span> <span>Yeni Görsel Ekle</span>
    </div>

    <div class="cg-page-header">
        <div>
            <h1 class="cg-page-title">Yeni Görsel Ekle</h1>
            <p class="cg-page-subtitle">Galeriye yeni bir görsel ekleyin.</p>
        </div>
        <div style="display:flex;gap:10px;">
            <a href="/Admin/Gallery/GalleryList/" class="btn-outline">✕ İptal</a>
            <button type="submit" form="cgForm" class="btn-accent">＋ Kaydet</button>
        </div>
    </div>

    <form id="cgForm" asp-area="Admin" asp-controller="Gallery" asp-action="CreateGallery" method="post">
        @Html.AntiForgeryToken()

        <div class="cg-card">
            <div class="cg-card-head">
                <div class="cg-card-icon">🖼️</div>
                <div>
                    <div class="cg-card-title">Görsel Bilgisi</div>
                    <div class="cg-card-subtitle">Görsel URL'sini girin</div>
                </div>
            </div>
            <div class="cg-card-body">
                <div class="cg-field">
                    <label>Görsel URL <span class="cg-required">*</span></label>
                    <input type="text" asp-for="ImageUrl" id="cgImgUrl" placeholder="/carola/assets/images/gallery/gallery-1.jpg" oninput="cgPreview(this.value)" autocomplete="off" />
                    <span asp-validation-for="ImageUrl" class="field-validation-error"></span>
                    <div class="cg-img-preview" id="cgImgPreview">
                        <img id="cgPreviewImg" src="" alt="Önizleme" />
                        <div class="cg-preview-ph">
                            <div class="cg-preview-icon">🖼️</div>
                            <div class="cg-preview-label">Görsel URL girerek önizleyebilirsiniz</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="cg-action-bar">
            <a href="/Admin/Gallery/GalleryList/" class="btn-outline">✕ İptal</a>
            <button type="submit" class="btn-accent">＋ Kaydet</button>
        </div>
    </form>
</div>

<script>
    function cgPreview(url) {
        var wrap = document.getElementById('cgImgPreview');
        var img = document.getElementById('cgPreviewImg');
        if (!url) { wrap.classList.remove('has-img'); img.src = ''; return; }
        img.onload = function() { wrap.classList.add('has-img'); };
        img.onerror = function() { wrap.classList.remove('has-img'); };
        img.src = url;
    }
</script>

@{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
