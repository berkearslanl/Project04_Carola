@model GetGalleryByIdDto
@using Carola.DtoLayer.Dtos.GalleryDtos
@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    :root { --bg-dark:#0d0f14; --bg-dark2:#13161e; --bg-dark3:#1a1e2a; --accent:#e8ff47; --accent-dim:rgba(232,255,71,.12); --danger:#ff5259; --border:rgba(255,255,255,.07); --text:#e2e8f0; --text-muted:#7a8499; --radius:12px; --radius-lg:18px; }
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    .ug-root { padding:28px; font-family:'DM Sans','Segoe UI',sans-serif; color:var(--text); }
    .ug-breadcrumb { display:flex; align-items:center; gap:6px; font-size:12px; color:var(--text-muted); margin-bottom:6px; }
    .ug-breadcrumb a { color:var(--text-muted); text-decoration:none; } .ug-breadcrumb a:hover { color:var(--text); } .ug-breadcrumb span { color:var(--text); }
    .ug-page-header { display:flex; align-items:flex-end; justify-content:space-between; gap:16px; margin-bottom:28px; flex-wrap:wrap; }
    .ug-page-title { font-family:'Syne',Georgia,sans-serif; font-size:26px; font-weight:700; color:var(--text); line-height:1; }
    .ug-page-subtitle { font-size:13px; color:var(--text-muted); margin-top:5px; }
    .btn-accent { background:var(--accent); color:#0d0f14; border:none; border-radius:10px; padding:9px 20px; font-size:13px; font-weight:600; font-family:inherit; cursor:pointer; display:inline-flex; align-items:center; gap:7px; text-decoration:none; transition:opacity .2s; }
    .btn-accent:hover { opacity:.85; color:#0d0f14; }
    .btn-outline { background:transparent; color:var(--text-muted); border:1px solid var(--border); border-radius:10px; padding:9px 18px; font-size:13px; font-weight:500; font-family:inherit; cursor:pointer; display:inline-flex; align-items:center; gap:7px; text-decoration:none; transition:background .2s,color .2s; }
    .btn-outline:hover { background:var(--bg-dark2); color:var(--text); }
    .ug-card { background:var(--bg-dark2); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; margin-bottom:20px; }
    .ug-card-head { display:flex; align-items:center; gap:10px; padding:16px 20px; border-bottom:1px solid var(--border); }
    .ug-card-icon { width:32px; height:32px; border-radius:9px; display:grid; place-items:center; font-size:15px; background:var(--accent-dim); color:var(--accent); }
    .ug-card-title { font-size:14px; font-weight:600; color:var(--text); }
    .ug-card-subtitle { font-size:12px; color:var(--text-muted); margin-top:1px; }
    .ug-card-body { padding:20px; }
    .ug-field { display:flex; flex-direction:column; gap:6px; margin-bottom:18px; }
    .ug-field:last-child { margin-bottom:0; }
    .ug-field label { font-size:12px; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:.6px; }
    .ug-required { color:var(--danger); margin-left:3px; }
    .ug-field input { background:var(--bg-dark3); border:1px solid var(--border); border-radius:10px; color:var(--text); padding:10px 14px; font-size:13px; font-family:inherit; outline:none; width:100%; transition:border .2s,box-shadow .2s; }
    .ug-field input::placeholder { color:var(--text-muted); }
    .ug-field input:focus { border-color:var(--accent); box-shadow:0 0 0 3px var(--accent-dim); }
    .field-validation-error { font-size:11px; color:var(--danger); }
    .input-validation-error { border-color:rgba(255,82,89,.5) !important; box-shadow:0 0 0 3px rgba(255,82,89,.1) !important; }
    .ug-action-bar { display:flex; align-items:center; justify-content:flex-end; gap:10px; padding-top:20px; border-top:1px solid var(--border); margin-top:4px; }
    .ug-id-badge { display:inline-flex; align-items:center; gap:6px; background:var(--accent-dim); border:1px solid rgba(232,255,71,.2); border-radius:8px; padding:6px 12px; font-size:12px; color:var(--accent); font-weight:600; margin-bottom:20px; }
    .ug-img-preview { width:100%; height:180px; border-radius:10px; overflow:hidden; margin-top:10px; background:var(--bg-dark3); border:1px dashed var(--border); }
    .ug-img-preview img { width:100%; height:100%; object-fit:cover; }
</style>

<div class="ug-root">
    <div class="ug-breadcrumb">
        İçerik Yönetimi <span>›</span>
        <a href="/Admin/Gallery/GalleryList/">Galeri Listesi</a>
        <span>›</span> <span>Görsel Güncelle</span>
    </div>

    <div class="ug-page-header">
        <div>
            <h1 class="ug-page-title">Görsel Güncelle</h1>
            <p class="ug-page-subtitle">Mevcut galeri görselini düzenleyin.</p>
        </div>
        <div style="display:flex;gap:10px;">
            <a href="/Admin/Gallery/GalleryList/" class="btn-outline">✕ İptal</a>
            <button type="submit" form="ugForm" class="btn-accent">💾 Güncelle</button>
        </div>
    </div>

    <div class="ug-id-badge">🔑 Görsel #@Model.GalleryId</div>

    <form id="ugForm" asp-area="Admin" asp-controller="Gallery" asp-action="UpdateGallery" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="GalleryId" />

        <div class="ug-card">
            <div class="ug-card-head">
                <div class="ug-card-icon">🖼️</div>
                <div>
                    <div class="ug-card-title">Görsel Bilgisi</div>
                    <div class="ug-card-subtitle">Görsel URL'sini güncelleyin</div>
                </div>
            </div>
            <div class="ug-card-body">
                <div class="ug-field">
                    <label>Görsel URL <span class="ug-required">*</span></label>
                    <input type="text" asp-for="ImageUrl" id="ugImgUrl" oninput="ugPreview(this.value)" autocomplete="off" />
                    <span asp-validation-for="ImageUrl" class="field-validation-error"></span>
                    <div class="ug-img-preview">
                        <img id="ugPreviewImg" src="@Model.ImageUrl" alt="Önizleme" />
                    </div>
                </div>
            </div>
        </div>

        <div class="ug-action-bar">
            <a href="/Admin/Gallery/GalleryList/" class="btn-outline">✕ İptal</a>
            <button type="submit" class="btn-accent">💾 Güncelle</button>
        </div>
    </form>
</div>

<script>
    function ugPreview(url) {
        document.getElementById('ugPreviewImg').src = url;
    }
</script>

@{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
