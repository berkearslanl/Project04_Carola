@model Carola.WebUI.Areas.Admin.Models.ReportsViewModel
@using System.Text.Json
@{
    Layout = "~/Views/AdminLayout/Index.cshtml";

    // Chart.js için JSON dizileri
    var fuelLabels  = JsonSerializer.Serialize(Model.CarsByFuelType.Keys.ToList());
    var fuelData    = JsonSerializer.Serialize(Model.CarsByFuelType.Values.ToList());
    var catLabels   = JsonSerializer.Serialize(Model.CarsByCategory.Keys.ToList());
    var catData     = JsonSerializer.Serialize(Model.CarsByCategory.Values.ToList());
    var resLabels   = JsonSerializer.Serialize(Model.ReservationsByStatus.Keys.ToList());
    var resData     = JsonSerializer.Serialize(Model.ReservationsByStatus.Values.ToList());
}
<style>
    .rp-root { padding: 28px; font-family: 'DM Sans','Segoe UI',sans-serif; color: var(--text); }
    .rp-page-title { font-family: 'Syne',sans-serif; font-size: 22px; font-weight: 700; margin-bottom: 6px; }
    .rp-page-sub { font-size: 13px; color: var(--text-muted); margin-bottom: 28px; }

    /* Özet kartlar */
    .rp-summary { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-bottom: 28px; }
    @@media(max-width:900px){ .rp-summary{ grid-template-columns:repeat(2,1fr); } }
    @@media(max-width:520px){ .rp-summary{ grid-template-columns:1fr; } }
    .rp-sum-card { background: var(--bg-dark2); border: 1px solid var(--border); border-radius: 16px; padding: 18px 20px; }
    .rp-sum-label { font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 6px; }
    .rp-sum-val { font-family: 'Syne',sans-serif; font-size: 26px; font-weight: 700; color: var(--text); line-height: 1; }
    .rp-sum-sub { font-size: 11px; margin-top: 6px; }
    .rp-sum-sub.green { color: #30e0a1; }
    .rp-sum-sub.yellow { color: var(--accent); }
    .rp-sum-sub.blue { color: var(--accent2); }

    /* Grafik grid */
    .rp-charts { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
    @@media(max-width:820px){ .rp-charts{ grid-template-columns:1fr; } }
    .rp-chart-card { background: var(--bg-dark2); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
    .rp-chart-head { display: flex; align-items: center; gap: 8px; padding: 14px 20px; border-bottom: 1px solid var(--border); font-size: 13px; font-weight: 600; color: var(--text); }
    .rp-chart-body { padding: 20px; position: relative; height: 260px; display: flex; align-items: center; justify-content: center; }

    /* Tek geniş kart */
    .rp-chart-card.full { grid-column: 1 / -1; }

    /* Araç durumu bar */
    .rp-avail { display: flex; flex-direction: column; gap: 14px; padding: 20px; }
    .rp-avail-row { display: flex; flex-direction: column; gap: 6px; }
    .rp-avail-label { display: flex; justify-content: space-between; font-size: 12px; }
    .rp-avail-label span:first-child { color: var(--text-muted); }
    .rp-avail-label span:last-child { font-weight: 600; color: var(--text); }
    .rp-bar-track { height: 8px; background: var(--bg-dark3); border-radius: 999px; overflow: hidden; }
    .rp-bar-fill { height: 100%; border-radius: 999px; transition: width .6s ease; }
    .rp-bar-fill.green  { background: #30e0a1; }
    .rp-bar-fill.red    { background: var(--danger); }
    .rp-bar-fill.yellow { background: var(--accent); }
    .rp-bar-fill.blue   { background: var(--accent2); }
</style>

<div class="rp-root">

    <div class="rp-page-title">📊 Raporlar</div>
    <div class="rp-page-sub">Güncel verilerinize dayalı istatistik ve grafikler.</div>

    <!-- Özet Kartlar -->
    <div class="rp-summary">
        <div class="rp-sum-card">
            <div class="rp-sum-label">Toplam Araç</div>
            <div class="rp-sum-val">@Model.TotalCars</div>
            <div class="rp-sum-sub green">@Model.AvailableCars müsait / @Model.RentedCars kirada</div>
        </div>
        <div class="rp-sum-card">
            <div class="rp-sum-label">Toplam Rezervasyon</div>
            <div class="rp-sum-val">@Model.TotalReservations</div>
            <div class="rp-sum-sub blue">@Model.ReservationsByStatus.GetValueOrDefault("Aktif", 0) aktif</div>
        </div>
        <div class="rp-sum-card">
            <div class="rp-sum-label">Toplam Gelir</div>
            <div class="rp-sum-val">@Model.TotalRevenue.ToString("N0") ₺</div>
            <div class="rp-sum-sub yellow">@Model.ActiveRevenue.ToString("N0") ₺ aktif</div>
        </div>
        <div class="rp-sum-card">
            <div class="rp-sum-label">Müşteri / Lokasyon</div>
            <div class="rp-sum-val">@Model.TotalCustomers</div>
            <div class="rp-sum-sub blue">@Model.TotalLocations şube, @Model.TotalBrands marka</div>
        </div>
    </div>

    <!-- Grafikler Satır 1 -->
    <div class="rp-charts">

        <!-- Yakıt Tipi Dağılımı - Doughnut -->
        <div class="rp-chart-card">
            <div class="rp-chart-head">⛽ Yakıt Tipine Göre Araçlar</div>
            <div class="rp-chart-body">
                <canvas id="chartFuel"></canvas>
            </div>
        </div>

        <!-- Rezervasyon Durumu - Doughnut -->
        <div class="rp-chart-card">
            <div class="rp-chart-head">📋 Rezervasyon Durumu Dağılımı</div>
            <div class="rp-chart-body">
                <canvas id="chartRes"></canvas>
            </div>
        </div>

        <!-- Kategori Dağılımı - Bar -->
        <div class="rp-chart-card full">
            <div class="rp-chart-head">🏷️ Kategoriye Göre Araç Sayısı</div>
            <div class="rp-chart-body" style="height:280px;">
                <canvas id="chartCat"></canvas>
            </div>
        </div>

    </div>

    <!-- Araç Müsaitlik Durumu -->
    <div class="rp-chart-card" style="margin-bottom:20px;">
        <div class="rp-chart-head">🚗 Araç Durum Özeti</div>
        <div class="rp-avail">
            @{
                int total = Model.TotalCars > 0 ? Model.TotalCars : 1;
                int pctAvail = Model.AvailableCars * 100 / total;
                int pctRented = Model.RentedCars * 100 / total;
            }
            <div class="rp-avail-row">
                <div class="rp-avail-label">
                    <span>Müsait Araçlar</span>
                    <span>@Model.AvailableCars / @Model.TotalCars (%@pctAvail)</span>
                </div>
                <div class="rp-bar-track">
                    <div class="rp-bar-fill green" style="width:@pctAvail%"></div>
                </div>
            </div>
            <div class="rp-avail-row">
                <div class="rp-avail-label">
                    <span>Kiradaki Araçlar</span>
                    <span>@Model.RentedCars / @Model.TotalCars (%@pctRented)</span>
                </div>
                <div class="rp-bar-track">
                    <div class="rp-bar-fill red" style="width:@pctRented%"></div>
                </div>
            </div>
            <div class="rp-avail-row">
                <div class="rp-avail-label">
                    <span>Aktif Rezervasyon Geliri</span>
                    <span>@Model.ActiveRevenue.ToString("N0") ₺ / @Model.TotalRevenue.ToString("N0") ₺</span>
                </div>
                <div class="rp-bar-track">
                    @{ int pctRev = Model.TotalRevenue > 0 ? (int)(Model.ActiveRevenue * 100 / Model.TotalRevenue) : 0; }
                    <div class="rp-bar-fill yellow" style="width:@pctRev%"></div>
                </div>
            </div>
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function () {
    var ACCENT   = '#e8ff47';
    var ACCENT2  = '#6c8cff';
    var GREEN    = '#30e0a1';
    var DANGER   = '#ff5259';
    var ORANGE   = '#ff9f47';
    var PURPLE   = '#a78bfa';
    var PALETTE  = [ACCENT, ACCENT2, GREEN, DANGER, ORANGE, PURPLE, '#67e8f9', '#f472b6'];

    var chartDefaults = {
        plugins: {
            legend: {
                labels: { color: '#b0b8c8', font: { family: 'DM Sans', size: 12 }, boxWidth: 14, padding: 16 }
            }
        }
    };

    // Yakıt tipi - Doughnut
    var fuelLabels = @Html.Raw(fuelLabels);
    var fuelData   = @Html.Raw(fuelData);
    new Chart(document.getElementById('chartFuel'), {
        type: 'doughnut',
        data: {
            labels: fuelLabels,
            datasets: [{ data: fuelData, backgroundColor: PALETTE, borderWidth: 0, hoverOffset: 6 }]
        },
        options: { ...chartDefaults, cutout: '65%', maintainAspectRatio: false }
    });

    // Rezervasyon durumu - Doughnut
    var resLabels = @Html.Raw(resLabels);
    var resData   = @Html.Raw(resData);
    var resColors = resLabels.map(function(l) {
        if (l === 'Aktif' || l === 'Onaylandı') return GREEN;
        if (l === 'Bekliyor') return ACCENT;
        if (l === 'İptal') return DANGER;
        return ACCENT2;
    });
    new Chart(document.getElementById('chartRes'), {
        type: 'doughnut',
        data: {
            labels: resLabels,
            datasets: [{ data: resData, backgroundColor: resColors, borderWidth: 0, hoverOffset: 6 }]
        },
        options: { ...chartDefaults, cutout: '65%', maintainAspectRatio: false }
    });

    // Kategori - Bar
    var catLabels = @Html.Raw(catLabels);
    var catData   = @Html.Raw(catData);
    new Chart(document.getElementById('chartCat'), {
        type: 'bar',
        data: {
            labels: catLabels,
            datasets: [{
                label: 'Araç Sayısı',
                data: catData,
                backgroundColor: catLabels.map(function(_, i){ return PALETTE[i % PALETTE.length]; }),
                borderRadius: 8,
                borderSkipped: false,
                barPercentage: 0.55
            }]
        },
        options: {
            ...chartDefaults,
            maintainAspectRatio: false,
            scales: {
                x: { ticks: { color: '#b0b8c8', font: { family: 'DM Sans' } }, grid: { color: 'rgba(255,255,255,.04)' } },
                y: { ticks: { color: '#b0b8c8', stepSize: 1, font: { family: 'DM Sans' } }, grid: { color: 'rgba(255,255,255,.06)' }, beginAtZero: true }
            }
        }
    });
})();
</script>
