@model List<ResultSliderDto>
@using Carola.DtoLayer.Dtos.SliderDtos
@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
    var totalCount = Model.Count();
}

<style>
    :root {
        --bg-dark: #0d0f14; --bg-dark2: #13161e; --bg-dark3: #1a1e2a;
        --accent: #e8ff47; --accent-dim: rgba(232,255,71,.12);
        --accent2: #4f8dff; --accent2-dim: rgba(79,141,255,.12);
        --danger: #ff5259; --success: #30e0a1;
        --border: rgba(255,255,255,.07); --text: #e2e8f0; --text-muted: #7a8499;
        --radius: 12px; --radius-lg: 18px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    .sl-root { padding: 28px; font-family: 'DM Sans','Segoe UI',sans-serif; color: var(--text); }
    .sl-breadcrumb { display:flex; align-items:center; gap:6px; font-size:12px; color:var(--text-muted); margin-bottom:6px; }
    .sl-breadcrumb span { color:var(--text); }
    .sl-page-header { display:flex; align-items:flex-end; justify-content:space-between; gap:16px; margin-bottom:24px; flex-wrap:wrap; }
    .sl-page-title { font-family:'Syne',Georgia,sans-serif; font-size:26px; font-weight:700; color:var(--text); line-height:1; }
    .sl-page-subtitle { font-size:13px; color:var(--text-muted); margin-top:5px; }
    .btn-accent { background:var(--accent); color:#0d0f14; border:none; border-radius:10px; padding:9px 18px; font-size:13px; font-weight:600; font-family:inherit; cursor:pointer; display:inline-flex; align-items:center; gap:7px; text-decoration:none; transition:opacity .2s; }
    .btn-accent:hover { opacity:.85; color:#0d0f14; }
    .btn-edit { background:var(--accent2-dim); color:var(--accent2); border:1px solid rgba(79,141,255,.25); border-radius:8px; padding:6px 13px; font-size:12px; font-weight:600; font-family:inherit; cursor:pointer; display:inline-flex; align-items:center; gap:5px; text-decoration:none; transition:background .2s; }
    .btn-edit:hover { background:rgba(79,141,255,.2); color:var(--accent2); }
    .btn-danger { background:rgba(255,82,89,.1); color:var(--danger); border:1px solid rgba(255,82,89,.2); border-radius:8px; padding:6px 13px; font-size:12px; font-weight:600; font-family:inherit; cursor:pointer; display:inline-flex; align-items:center; gap:5px; text-decoration:none; transition:background .2s; }
    .btn-danger:hover { background:rgba(255,82,89,.18); color:var(--danger); }
    .sl-stats { display:grid; grid-template-columns:repeat(1,1fr); gap:14px; margin-bottom:22px; }
    .sl-stat-card { background:var(--bg-dark2); border:1px solid var(--border); border-radius:var(--radius); padding:16px 18px; display:flex; align-items:center; gap:14px; }
    .sl-stat-icon { width:40px; height:40px; border-radius:10px; display:grid; place-items:center; font-size:18px; flex-shrink:0; }
    .sl-stat-icon.yellow { background:var(--accent-dim); color:var(--accent); }
    .sl-stat-num { font-family:'Syne',sans-serif; font-size:24px; font-weight:700; line-height:1; }
    .sl-stat-label { font-size:12px; color:var(--text-muted); margin-top:3px; }
    .sl-toolbar { display:flex; align-items:center; gap:12px; margin-bottom:18px; flex-wrap:wrap; }
    .sl-search-wrap { position:relative; flex:1; min-width:200px; max-width:340px; }
    .sl-search-wrap input { width:100%; background:var(--bg-dark2); border:1px solid var(--border); border-radius:10px; color:var(--text); padding:9px 13px 9px 36px; font-size:13px; font-family:inherit; outline:none; transition:border .2s; }
    .sl-search-wrap input:focus { border-color:var(--accent); box-shadow:0 0 0 3px var(--accent-dim); }
    .sl-search-wrap input::placeholder { color:var(--text-muted); }
    .sl-search-icon { position:absolute; left:12px; top:50%; transform:translateY(-50%); font-size:14px; color:var(--text-muted); pointer-events:none; }
    .sl-result-info { font-size:12px; color:var(--text-muted); margin-bottom:14px; }
    .sl-result-info strong { color:var(--text); }
    .sl-table { width:100%; border-collapse:collapse; background:var(--bg-dark2); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; }
    .sl-table th { background:var(--bg-dark3); padding:12px 16px; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.6px; color:var(--text-muted); text-align:left; border-bottom:1px solid var(--border); }
    .sl-table td { padding:14px 16px; font-size:13px; color:var(--text); border-bottom:1px solid var(--border); vertical-align:middle; }
    .sl-table tr:last-child td { border-bottom:none; }
    .sl-table tr:hover td { background:rgba(255,255,255,.02); }
    .sl-slide-img { width:80px; height:50px; object-fit:cover; border-radius:8px; border:1px solid var(--border); }
    .sl-slide-img-ph { width:80px; height:50px; border-radius:8px; background:var(--bg-dark3); border:1px dashed var(--border); display:flex; align-items:center; justify-content:center; color:var(--text-muted); font-size:18px; }
    .sl-title-cell { font-weight:600; color:var(--text); }
    .sl-desc-cell { color:var(--text-muted); font-size:12px; max-width:220px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .sl-id-badge { display:inline-block; background:var(--accent-dim); border:1px solid rgba(232,255,71,.2); color:var(--accent); border-radius:6px; padding:2px 8px; font-size:11px; font-weight:600; }
    .sl-actions { display:flex; gap:8px; }
    .sl-empty { text-align:center; padding:60px 20px; color:var(--text-muted); }
    .sl-empty-icon { font-size:42px; opacity:.45; margin-bottom:12px; }
    .sl-modal-backdrop { display:none; position:fixed; inset:0; background:rgba(0,0,0,.7); z-index:200; align-items:center; justify-content:center; backdrop-filter:blur(4px); }
    .sl-modal-backdrop.open { display:flex; }
    .sl-modal { background:var(--bg-dark2); border:1px solid var(--border); border-radius:var(--radius-lg); padding:32px 28px 28px; width:100%; max-width:380px; text-align:center; position:relative; }
    .sl-modal-close { position:absolute; top:14px; right:16px; background:none; border:none; color:var(--text-muted); font-size:18px; cursor:pointer; }
    .sl-modal-icon { font-size:38px; margin-bottom:10px; }
    .sl-modal-title { font-family:'Syne',sans-serif; font-size:18px; font-weight:700; margin-bottom:10px; }
    .sl-modal-msg { font-size:13px; color:var(--text-muted); line-height:1.65; margin-bottom:24px; }
    .sl-modal-actions { display:flex; gap:10px; justify-content:center; }
</style>

<div class="sl-root">
    <div class="sl-breadcrumb">İçerik Yönetimi <span>›</span> <span>Slider Listesi</span></div>

    <div class="sl-page-header">
        <div>
            <h1 class="sl-page-title">Slider Yönetimi</h1>
            <p class="sl-page-subtitle">Ana sayfadaki slider öğelerini yönetin.</p>
        </div>
        <a href="/Admin/Slider/CreateSlider/" class="btn-accent">＋ Yeni Slider Ekle</a>
    </div>

    <div class="sl-stats">
        <div class="sl-stat-card">
            <div class="sl-stat-icon yellow">🖼️</div>
            <div>
                <div class="sl-stat-num">@totalCount</div>
                <div class="sl-stat-label">Toplam Slider</div>
            </div>
        </div>
    </div>

    <div class="sl-toolbar">
        <div class="sl-search-wrap">
            <span class="sl-search-icon">🔍</span>
            <input type="text" id="slSearch" placeholder="Slider ara..." oninput="slRender()" />
        </div>
    </div>

    <div class="sl-result-info" id="slResultInfo"></div>

    <table class="sl-table" id="slTable">
        <thead>
            <tr>
                <th>#</th>
                <th>Görsel</th>
                <th>Başlık</th>
                <th>Açıklama</th>
                <th>Arka Plan</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody id="slBody"></tbody>
    </table>
</div>

<div class="sl-modal-backdrop" id="slConfirmModal">
    <div class="sl-modal">
        <button class="sl-modal-close" onclick="slCloseModal()">✕</button>
        <div class="sl-modal-icon">🗑️</div>
        <div class="sl-modal-title">Slider'ı Sil</div>
        <p class="sl-modal-msg" id="slConfirmMsg"></p>
        <div class="sl-modal-actions">
            <button class="btn-accent" onclick="slCloseModal()" style="background:var(--bg-dark3);color:var(--text);border:1px solid var(--border);">İptal</button>
            <form id="slDeleteForm" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-danger">🗑️ Evet, Sil</button>
            </form>
        </div>
    </div>
</div>

<script>
    const SL_DATA = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(s => new {
        s.SliderId, s.Title, s.Description, s.BackgroundImage, s.Image
    })));

    function slGetFiltered() {
        const q = document.getElementById('slSearch').value.toLowerCase();
        return SL_DATA.filter(s => s.Title.toLowerCase().includes(q) || s.Description.toLowerCase().includes(q));
    }

    function slRender() {
        const items = slGetFiltered();
        document.getElementById('slResultInfo').innerHTML = `<strong>${items.length}</strong> slider listeleniyor`;
        const tbody = document.getElementById('slBody');
        if (items.length === 0) {
            tbody.innerHTML = `<tr><td colspan="6" class="sl-empty"><div class="sl-empty-icon">🔍</div><p>Sonuç bulunamadı.</p></td></tr>`;
            return;
        }
        tbody.innerHTML = items.map(s => `
            <tr>
                <td><span class="sl-id-badge">#${s.SliderId}</span></td>
                <td>${s.Image ? `<img class="sl-slide-img" src="${slEsc(s.Image)}" alt="" onerror="this.style.display='none'" />` : `<div class="sl-slide-img-ph">🖼️</div>`}</td>
                <td class="sl-title-cell">${slEsc(s.Title)}</td>
                <td class="sl-desc-cell" title="${slEsc(s.Description)}">${slEsc(s.Description)}</td>
                <td class="sl-desc-cell" title="${slEsc(s.BackgroundImage)}">${s.BackgroundImage ? slEsc(s.BackgroundImage.length > 30 ? '...' + s.BackgroundImage.slice(-27) : s.BackgroundImage) : '—'}</td>
                <td>
                    <div class="sl-actions">
                        <a href="/Admin/Slider/UpdateSlider/${s.SliderId}" class="btn-edit">✏️ Düzenle</a>
                        <button class="btn-danger" onclick="slConfirmDelete(${s.SliderId},'${slEsc(s.Title)}')">🗑️ Sil</button>
                    </div>
                </td>
            </tr>`).join('');
    }

    function slConfirmDelete(id, title) {
        document.getElementById('slConfirmMsg').innerHTML = `<strong>${slEsc(title)}</strong> slider'ını silmek istediğinizden emin misiniz?<br>Bu işlem geri alınamaz.`;
        document.getElementById('slDeleteForm').action = `/Admin/Slider/DeleteSlider/${id}`;
        document.getElementById('slConfirmModal').classList.add('open');
    }

    function slCloseModal() { document.getElementById('slConfirmModal').classList.remove('open'); }
    document.getElementById('slConfirmModal').addEventListener('click', function(e) { if (e.target === this) slCloseModal(); });

    function slEsc(str) {
        if (!str) return '';
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#x27;');
    }

    slRender();
</script>
