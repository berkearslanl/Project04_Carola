@model GetSliderByIdDto
@using Carola.DtoLayer.Dtos.SliderDtos
@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    :root { --bg-dark:#0d0f14; --bg-dark2:#13161e; --bg-dark3:#1a1e2a; --accent:#e8ff47; --accent-dim:rgba(232,255,71,.12); --danger:#ff5259; --success:#30e0a1; --border:rgba(255,255,255,.07); --text:#e2e8f0; --text-muted:#7a8499; --radius:12px; --radius-lg:18px; }
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    .us-root { padding:28px; font-family:'DM Sans','Segoe UI',sans-serif; color:var(--text); }
    .us-breadcrumb { display:flex; align-items:center; gap:6px; font-size:12px; color:var(--text-muted); margin-bottom:6px; }
    .us-breadcrumb a { color:var(--text-muted); text-decoration:none; } .us-breadcrumb a:hover { color:var(--text); } .us-breadcrumb span { color:var(--text); }
    .us-page-header { display:flex; align-items:flex-end; justify-content:space-between; gap:16px; margin-bottom:28px; flex-wrap:wrap; }
    .us-page-title { font-family:'Syne',Georgia,sans-serif; font-size:26px; font-weight:700; color:var(--text); line-height:1; }
    .us-page-subtitle { font-size:13px; color:var(--text-muted); margin-top:5px; }
    .btn-accent { background:var(--accent); color:#0d0f14; border:none; border-radius:10px; padding:9px 20px; font-size:13px; font-weight:600; font-family:inherit; cursor:pointer; display:inline-flex; align-items:center; gap:7px; text-decoration:none; transition:opacity .2s; }
    .btn-accent:hover { opacity:.85; color:#0d0f14; }
    .btn-outline { background:transparent; color:var(--text-muted); border:1px solid var(--border); border-radius:10px; padding:9px 18px; font-size:13px; font-weight:500; font-family:inherit; cursor:pointer; display:inline-flex; align-items:center; gap:7px; text-decoration:none; transition:background .2s,color .2s; }
    .btn-outline:hover { background:var(--bg-dark2); color:var(--text); }
    .us-card { background:var(--bg-dark2); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; margin-bottom:20px; }
    .us-card-head { display:flex; align-items:center; gap:10px; padding:16px 20px; border-bottom:1px solid var(--border); }
    .us-card-icon { width:32px; height:32px; border-radius:9px; display:grid; place-items:center; font-size:15px; flex-shrink:0; }
    .us-card-icon.yellow { background:var(--accent-dim); color:var(--accent); }
    .us-card-title { font-size:14px; font-weight:600; color:var(--text); }
    .us-card-subtitle { font-size:12px; color:var(--text-muted); margin-top:1px; }
    .us-card-body { padding:20px; }
    .us-field { display:flex; flex-direction:column; gap:6px; margin-bottom:18px; }
    .us-field:last-child { margin-bottom:0; }
    .us-field label { font-size:12px; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:.6px; }
    .us-required { color:var(--danger); margin-left:3px; }
    .us-field input, .us-field textarea { background:var(--bg-dark3); border:1px solid var(--border); border-radius:10px; color:var(--text); padding:10px 14px; font-size:13px; font-family:inherit; outline:none; width:100%; transition:border .2s,box-shadow .2s; }
    .us-field textarea { resize:vertical; min-height:90px; }
    .us-field input::placeholder, .us-field textarea::placeholder { color:var(--text-muted); }
    .us-field input:focus, .us-field textarea:focus { border-color:var(--accent); box-shadow:0 0 0 3px var(--accent-dim); }
    .field-validation-error { font-size:11px; color:var(--danger); }
    .input-validation-error { border-color:rgba(255,82,89,.5) !important; box-shadow:0 0 0 3px rgba(255,82,89,.1) !important; }
    .us-action-bar { display:flex; align-items:center; justify-content:flex-end; gap:10px; padding-top:20px; border-top:1px solid var(--border); margin-top:4px; }
    .us-id-badge { display:inline-flex; align-items:center; gap:6px; background:var(--accent-dim); border:1px solid rgba(232,255,71,.2); border-radius:8px; padding:6px 12px; font-size:12px; color:var(--accent); font-weight:600; margin-bottom:20px; }
    .us-img-preview { width:100%; height:120px; border-radius:10px; background:var(--bg-dark3); border:1px dashed var(--border); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; overflow:hidden; margin-top:10px; }
    .us-img-preview img { width:100%; height:100%; object-fit:cover; }
    .us-preview-ph { display:flex; flex-direction:column; align-items:center; gap:6px; }
    .us-preview-icon { font-size:24px; color:var(--text-muted); }
    .us-preview-label { font-size:11px; color:var(--text-muted); }
</style>

<div class="us-root">
    <div class="us-breadcrumb">
        İçerik Yönetimi <span>›</span>
        <a href="/Admin/Slider/SliderList/">Slider Listesi</a>
        <span>›</span> <span>Slider Güncelle</span>
    </div>

    <div class="us-page-header">
        <div>
            <h1 class="us-page-title">Slider Güncelle</h1>
            <p class="us-page-subtitle">Mevcut slider öğesini düzenleyin.</p>
        </div>
        <div style="display:flex;gap:10px;">
            <a href="/Admin/Slider/SliderList/" class="btn-outline">✕ İptal</a>
            <button type="button" class="btn-accent" onclick="document.getElementById('usForm').submit()">💾 Güncelle</button>
        </div>
    </div>

    <div class="us-id-badge">🔑 Slider #@Model.SliderId</div>

    <form id="usForm" asp-area="Admin" asp-controller="Slider" asp-action="UpdateSlider" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="SliderId" />

        <div class="us-card">
            <div class="us-card-head">
                <div class="us-card-icon yellow">🖼️</div>
                <div>
                    <div class="us-card-title">Slider Bilgileri</div>
                    <div class="us-card-subtitle">Başlık, açıklama ve görsel URL'lerini güncelleyin</div>
                </div>
            </div>
            <div class="us-card-body">
                <div class="us-field">
                    <label>Başlık <span class="us-required">*</span></label>
                    <input type="text" asp-for="Title" placeholder="Slider başlığı" maxlength="100" autocomplete="off" />
                    <span asp-validation-for="Title" class="field-validation-error"></span>
                </div>

                <div class="us-field">
                    <label>Açıklama <span class="us-required">*</span></label>
                    <textarea asp-for="Description" placeholder="Slider açıklaması..." maxlength="500"></textarea>
                    <span asp-validation-for="Description" class="field-validation-error"></span>
                </div>

                <div class="us-field">
                    <label>Arka Plan Görseli URL <span class="us-required">*</span></label>
                    <input type="text" asp-for="BackgroundImage" id="usBgImg" placeholder="/carola/assets/images/sliders/slider-1.jpg" oninput="usBgPreview(this.value)" autocomplete="off" />
                    <span asp-validation-for="BackgroundImage" class="field-validation-error"></span>
                    <div class="us-img-preview" id="usBgPreview">
                        <img id="usBgPreviewImg" src="@Model.BackgroundImage" alt="Arka Plan" />
                    </div>
                </div>

                <div class="us-field">
                    <label>Araç Görseli URL <span class="us-required">*</span></label>
                    <input type="text" asp-for="Image" id="usImg" placeholder="/carola/assets/images/sliders/car.png" oninput="usImgPreview(this.value)" autocomplete="off" />
                    <span asp-validation-for="Image" class="field-validation-error"></span>
                    <div class="us-img-preview" id="usImgPreview">
                        <img id="usImgPreviewImg" src="@Model.Image" alt="Araç Görseli" />
                    </div>
                </div>
            </div>
        </div>

        <div class="us-action-bar">
            <a href="/Admin/Slider/SliderList/" class="btn-outline">✕ İptal</a>
            <button type="submit" class="btn-accent">💾 Güncelle</button>
        </div>
    </form>
</div>

<script>
    function usBgPreview(url) {
        document.getElementById('usBgPreviewImg').src = url;
    }
    function usImgPreview(url) {
        document.getElementById('usImgPreviewImg').src = url;
    }
</script>

@{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
