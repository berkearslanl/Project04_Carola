@model List<ResultCategoryDto>
@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
    var totalCount = Model.Count();
}

<style>
    :root {
        --bg-dark: #0d0f14; --bg-dark2: #13161e; --bg-dark3: #1a1e2a;
        --accent: #e8ff47; --accent-dim: rgba(232,255,71,.12);
        --accent2: #4f8dff; --accent2-dim: rgba(79,141,255,.12);
        --danger: #ff5259; --success: #30e0a1;
        --border: rgba(255,255,255,.07); --text: #e2e8f0; --text-muted: #7a8499;
        --radius: 12px; --radius-lg: 18px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .cat-root { padding: 28px; font-family: 'DM Sans','Segoe UI',sans-serif; color: var(--text); }

    .cat-breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text-muted); margin-bottom: 6px; }
    .cat-breadcrumb span { color: var(--text); }

    .cat-page-header { display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
    .cat-page-title { font-family: 'Syne',Georgia,sans-serif; font-size: 26px; font-weight: 700; color: var(--text); line-height: 1; }
    .cat-page-subtitle { font-size: 13px; color: var(--text-muted); margin-top: 5px; }

    .btn-accent { background: var(--accent); color: #0d0f14; border: none; border-radius: 10px; padding: 9px 18px; font-size: 13px; font-weight: 600; font-family: inherit; cursor: pointer; display: inline-flex; align-items: center; gap: 7px; text-decoration: none; transition: opacity .2s; }
    .btn-accent:hover { opacity: .85; color: #0d0f14; }
    .btn-edit { background: var(--accent2-dim); color: var(--accent2); border: 1px solid rgba(79,141,255,.25); border-radius: 8px; padding: 6px 13px; font-size: 12px; font-weight: 600; font-family: inherit; cursor: pointer; display: inline-flex; align-items: center; gap: 5px; text-decoration: none; transition: background .2s; }
    .btn-edit:hover { background: rgba(79,141,255,.2); color: var(--accent2); }
    .btn-danger { background: rgba(255,82,89,.1); color: var(--danger); border: 1px solid rgba(255,82,89,.2); border-radius: 8px; padding: 6px 13px; font-size: 12px; font-weight: 600; font-family: inherit; cursor: pointer; display: inline-flex; align-items: center; gap: 5px; text-decoration: none; transition: background .2s; }
    .btn-danger:hover { background: rgba(255,82,89,.18); color: var(--danger); }

    .cat-stat-card { background: var(--bg-dark2); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px 18px; display: inline-flex; align-items: center; gap: 14px; margin-bottom: 22px; }
    .cat-stat-icon { width: 40px; height: 40px; border-radius: 10px; display: grid; place-items: center; font-size: 18px; background: var(--accent-dim); color: var(--accent); }
    .cat-stat-num { font-family: 'Syne',sans-serif; font-size: 24px; font-weight: 700; line-height: 1; }
    .cat-stat-label { font-size: 12px; color: var(--text-muted); margin-top: 3px; }

    .cat-toolbar { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; flex-wrap: wrap; }
    .cat-search-wrap { position: relative; flex: 1; min-width: 200px; max-width: 360px; }
    .cat-search-wrap input { width: 100%; background: var(--bg-dark2); border: 1px solid var(--border); border-radius: 10px; color: var(--text); padding: 9px 13px 9px 36px; font-size: 13px; font-family: inherit; outline: none; transition: border .2s; }
    .cat-search-wrap input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
    .cat-search-wrap input::placeholder { color: var(--text-muted); }
    .cat-search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); font-size: 14px; color: var(--text-muted); pointer-events: none; }
    .cat-result-info { font-size: 12px; color: var(--text-muted); margin-bottom: 14px; }
    .cat-result-info strong { color: var(--text); }

    .cat-table-wrap { background: var(--bg-dark2); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; }
    .cat-table { width: 100%; border-collapse: collapse; }
    .cat-table thead tr { border-bottom: 1px solid var(--border); }
    .cat-table th { padding: 13px 18px; text-align: left; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: .06em; white-space: nowrap; }
    .cat-table td { padding: 14px 18px; font-size: 13px; color: var(--text); border-bottom: 1px solid var(--border); }
    .cat-table tbody tr:last-child td { border-bottom: none; }
    .cat-table tbody tr { transition: background .15s; }
    .cat-table tbody tr:hover { background: rgba(255,255,255,.025); }

    .cat-id-badge { display: inline-flex; align-items: center; background: var(--bg-dark3); border: 1px solid var(--border); border-radius: 6px; padding: 2px 9px; font-size: 11px; color: var(--text-muted); font-family: monospace; }
    .cat-name-cell { display: flex; align-items: center; gap: 12px; }
    .cat-avatar { width: 38px; height: 38px; border-radius: 10px; background: var(--accent-dim); border: 1px solid rgba(232,255,71,.2); display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 700; color: var(--accent); font-family: 'Syne',sans-serif; flex-shrink: 0; }
    .cat-name-text { font-weight: 600; font-size: 14px; }
    .cat-actions { display: flex; gap: 8px; }

    .cat-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60px 20px; gap: 12px; color: var(--text-muted); }
    .cat-empty-icon { font-size: 42px; opacity: .45; }

    .cat-modal-backdrop { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.7); z-index: 200; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
    .cat-modal-backdrop.open { display: flex; }
    .cat-modal { background: var(--bg-dark2); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 32px 28px 28px; width: 100%; max-width: 380px; text-align: center; position: relative; }
    .cat-modal-close { position: absolute; top: 14px; right: 16px; background: none; border: none; color: var(--text-muted); font-size: 18px; cursor: pointer; }
    .cat-modal-icon { font-size: 38px; margin-bottom: 10px; }
    .cat-modal-title { font-family: 'Syne',sans-serif; font-size: 18px; font-weight: 700; margin-bottom: 10px; }
    .cat-modal-msg { font-size: 13px; color: var(--text-muted); line-height: 1.65; margin-bottom: 24px; }
    .cat-modal-actions { display: flex; gap: 10px; justify-content: center; }
</style>

<div class="cat-root">

    <div class="cat-breadcrumb">
        Admin <span>›</span> <span>Kategori Listesi</span>
    </div>

    <div class="cat-page-header">
        <div>
            <h1 class="cat-page-title">Kategori Yönetimi</h1>
            <p class="cat-page-subtitle">Araç kategorilerini görüntüleyin ve yönetin.</p>
        </div>
        <a asp-area="Admin" asp-controller="Category" asp-action="CreateCategory" class="btn-accent">
            ＋ Yeni Kategori Ekle
        </a>
    </div>

    <div class="cat-stat-card">
        <div class="cat-stat-icon">🏷️</div>
        <div>
            <div class="cat-stat-num">@totalCount</div>
            <div class="cat-stat-label">Toplam Kategori</div>
        </div>
    </div>

    <div class="cat-toolbar">
        <div class="cat-search-wrap">
            <span class="cat-search-icon">🔍</span>
            <input type="text" id="catSearch" placeholder="Kategori ara..." oninput="catRender()" />
        </div>
    </div>

    <div class="cat-result-info" id="catResultInfo"></div>

    <div class="cat-table-wrap">
        <table class="cat-table" id="catTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Görsel</th>
                    <th>Kategori Adı</th>
                    <th style="text-align:right;">İşlemler</th>
                </tr>
            </thead>
            <tbody id="catTbody"></tbody>
        </table>
    </div>

</div>

<div class="cat-modal-backdrop" id="catConfirmModal">
    <div class="cat-modal">
        <button class="cat-modal-close" onclick="catCloseModal()">✕</button>
        <div class="cat-modal-icon">🗑️</div>
        <div class="cat-modal-title">Kategoriyi Sil</div>
        <p class="cat-modal-msg" id="catConfirmMsg"></p>
        <div class="cat-modal-actions">
            <button onclick="catCloseModal()" style="background:var(--bg-dark3);color:var(--text);border:1px solid var(--border);border-radius:10px;padding:9px 18px;font-size:13px;font-weight:600;font-family:inherit;cursor:pointer;">
                İptal
            </button>
            <form id="catDeleteForm" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-danger">🗑️ Evet, Sil</button>
            </form>
        </div>
    </div>
</div>

<script>
    var CAT_DATA = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(c => new {
        c.CategoryId,
        c.CategoryName,
        c.CategoryImage
    })));

    function catGetFiltered() {
        var q = document.getElementById('catSearch').value.toLowerCase();
        return CAT_DATA.filter(function(c) {
            return c.CategoryName.toLowerCase().indexOf(q) !== -1;
        });
    }

    function catEsc(str) {
        if (!str && str !== 0) return '';
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#x27;');
    }

    function catRender() {
        var items  = catGetFiltered();
        var tbody  = document.getElementById('catTbody');
        var info   = document.getElementById('catResultInfo');

        info.innerHTML = '<strong>' + items.length + '</strong> kategori listeleniyor';

        if (items.length === 0) {
            tbody.innerHTML =
                '<tr><td colspan="4">' +
                    '<div class="cat-empty">' +
                        '<div class="cat-empty-icon">🏷️</div>' +
                        '<p>Aramanızla eşleşen kategori bulunamadı.</p>' +
                    '</div>' +
                '</td></tr>';
            return;
        }

        tbody.innerHTML = items.map(function(c) {
            var initial = c.CategoryName ? c.CategoryName.charAt(0).toUpperCase() : '?';
            var imgCell = c.CategoryImage
                ? '<img src="' + catEsc(c.CategoryImage) + '" alt="" style="height:40px;width:60px;object-fit:contain;border-radius:6px;background:var(--bg-dark3);border:1px solid var(--border);padding:3px;" onerror="this.style.display=\'none\'" />'
                : '<div class="cat-avatar">' + catEsc(initial) + '</div>';
            return '<tr>' +
                '<td><span class="cat-id-badge">#' + c.CategoryId + '</span></td>' +
                '<td>' + imgCell + '</td>' +
                '<td>' +
                    '<div class="cat-name-cell">' +
                        '<span class="cat-name-text">' + catEsc(c.CategoryName) + '</span>' +
                    '</div>' +
                '</td>' +
                '<td style="text-align:right;">' +
                    '<div class="cat-actions" style="justify-content:flex-end;">' +
                        '<a href="/Admin/Category/UpdateCategory/' + c.CategoryId + '" class="btn-edit">✏️ Düzenle</a>' +
                        '<button class="btn-danger" onclick="catConfirmDelete(' + c.CategoryId + ',\'' + catEsc(c.CategoryName) + '\')">🗑️ Sil</button>' +
                    '</div>' +
                '</td>' +
            '</tr>';
        }).join('');
    }

    function catConfirmDelete(id, name) {
        document.getElementById('catConfirmMsg').innerHTML =
            '<strong>' + catEsc(name) + '</strong> kategorisini silmek istediğinizden emin misiniz?<br>Bu işlem geri alınamaz.';
        document.getElementById('catDeleteForm').action = '/Admin/Category/DeleteCategory/' + id;
        document.getElementById('catConfirmModal').classList.add('open');
    }

    function catCloseModal() {
        document.getElementById('catConfirmModal').classList.remove('open');
    }

    document.getElementById('catConfirmModal').addEventListener('click', function(e) {
        if (e.target === this) catCloseModal();
    });

    catRender();
</script>
