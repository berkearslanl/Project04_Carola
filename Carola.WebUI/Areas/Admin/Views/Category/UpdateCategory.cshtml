@model GetCategoryByIdDto
@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    :root {
        --bg-dark: #0d0f14;
        --bg-dark2: #13161e;
        --bg-dark3: #1a1e2a;
        --accent: #e8ff47;
        --accent-dim: rgba(232,255,71,.12);
        --danger: #ff5259;
        --success: #30e0a1;
        --border: rgba(255,255,255,.07);
        --text: #e2e8f0;
        --text-muted: #7a8499;
        --radius: 12px;
        --radius-lg: 18px;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .cc-root {
        padding: 28px;
        font-family: 'DM Sans','Segoe UI',sans-serif;
        color: var(--text);
    }

    .cc-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 6px;
    }

        .cc-breadcrumb a {
            color: var(--text-muted);
            text-decoration: none;
            transition: color .15s;
        }

            .cc-breadcrumb a:hover {
                color: var(--text);
            }

        .cc-breadcrumb span {
            color: var(--text);
        }

    .cc-page-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 28px;
        flex-wrap: wrap;
    }

    .cc-page-title {
        font-family: 'Syne',Georgia,sans-serif;
        font-size: 26px;
        font-weight: 700;
        color: var(--text);
        line-height: 1;
    }

    .cc-page-subtitle {
        font-size: 13px;
        color: var(--text-muted);
        margin-top: 5px;
    }

    .btn-accent {
        background: var(--accent);
        color: #0d0f14;
        border: none;
        border-radius: 10px;
        padding: 9px 20px;
        font-size: 13px;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        text-decoration: none;
        transition: opacity .2s;
    }

        .btn-accent:hover {
            opacity: .85;
            color: #0d0f14;
        }

    .btn-outline {
        background: transparent;
        color: var(--text-muted);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 9px 18px;
        font-size: 13px;
        font-weight: 500;
        font-family: inherit;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        text-decoration: none;
        transition: background .2s, color .2s;
    }

        .btn-outline:hover {
            background: var(--bg-dark2);
            color: var(--text);
        }

    .cc-id-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--accent-dim);
        border: 1px solid rgba(232,255,71,.2);
        border-radius: 8px;
        padding: 6px 12px;
        font-size: 12px;
        color: var(--accent);
        font-weight: 600;
        margin-bottom: 20px;
    }

    .cc-card {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }

    .cc-card-head {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
    }

    .cc-card-icon {
        width: 32px;
        height: 32px;
        border-radius: 9px;
        display: grid;
        place-items: center;
        font-size: 15px;
        flex-shrink: 0;
        background: var(--accent-dim);
        color: var(--accent);
    }

    .cc-card-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--text);
    }

    .cc-card-subtitle {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 1px;
    }

    .cc-card-body {
        padding: 24px;
    }

    .cc-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 20px;
    }

        .cc-field:last-child {
            margin-bottom: 0;
        }

        .cc-field label {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: .6px;
        }

        .cc-field input {
            background: var(--bg-dark3);
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--text);
            padding: 11px 14px;
            font-size: 14px;
            font-family: inherit;
            outline: none;
            width: 100%;
            transition: border .2s, box-shadow .2s;
        }

            .cc-field input::placeholder {
                color: var(--text-muted);
            }

            .cc-field input:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px var(--accent-dim);
            }

        .cc-field.has-error input {
            border-color: var(--danger);
            box-shadow: 0 0 0 3px rgba(255,82,89,.12);
        }

    .cc-err-msg {
        font-size: 11px;
        color: var(--danger);
        display: none;
    }

    .cc-field.has-error .cc-err-msg {
        display: block;
    }

    .cc-required {
        color: var(--danger);
        margin-left: 3px;
    }

    .cc-val-summary {
        background: rgba(255,82,89,.08);
        border: 1px solid rgba(255,82,89,.2);
        border-radius: 10px;
        padding: 12px 16px;
        margin-bottom: 20px;
        display: none;
    }

        .cc-val-summary.show {
            display: block;
        }

        .cc-val-summary p {
            font-size: 12px;
            color: var(--danger);
            line-height: 1.6;
        }

    .cc-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
        padding: 18px 24px;
        border-top: 1px solid var(--border);
        background: var(--bg-dark3);
    }
</style>

<div class="cc-root">

    <div class="cc-breadcrumb">
        Admin <span>›</span>
        <a asp-area="Admin" asp-controller="Category" asp-action="CategoryList">Kategori Listesi</a>
        <span>›</span>
        <span>Kategori Güncelle</span>
    </div>

    <div class="cc-page-header">
        <div>
            <h1 class="cc-page-title">Kategori Güncelle</h1>
            <p class="cc-page-subtitle">Mevcut kategori bilgilerini düzenleyin.</p>
        </div>
        <a asp-area="Admin" asp-controller="Category" asp-action="CategoryList" class="btn-outline">✕ İptal</a>
    </div>

    <div class="cc-id-badge">🔑 CategoryId — @Model.CategoryId</div>

    <div class="cc-val-summary" id="valSummary">
        <p id="valMsg"></p>
    </div>

    <div class="cc-card">
        <div class="cc-card-head">
            <div class="cc-card-icon">🏷️</div>
            <div>
                <div class="cc-card-title">Kategori Bilgileri</div>
                <div class="cc-card-subtitle">Kategorinin adını düzenleyin</div>
            </div>
        </div>
        <form id="ccForm"
              asp-area="Admin"
              asp-controller="Category"
              asp-action="UpdateCategory"
              method="post"
              novalidate>
            @Html.AntiForgeryToken()
            <div class="cc-card-body">

                <input type="hidden" name="CategoryId" value="@Model.CategoryId" />

                <div class="cc-field" id="fieldCategoryName">
                    <label>Kategori Adı <span class="cc-required">*</span></label>
                    <input asp-for="CategoryName"
                           id="CategoryName"
                           placeholder="ör. SUV, Sedan, Hatchback"
                           maxlength="100"
                           autocomplete="off" />
                    <span asp-validation-for="CategoryName" class="cc-err-msg" style="display:block;"></span>
                </div>

                <div class="cc-field" id="fieldCategoryImage">
                    <label>Kategori Görseli (URL) <span class="cc-required">*</span></label>
                    <input asp-for="CategoryImage"
                           id="CategoryImage"
                           placeholder="https://example.com/image.png"
                           autocomplete="off"
                           oninput="ccPreviewImage(this.value)" />
                    <span asp-validation-for="CategoryImage" class="cc-err-msg" style="display:block;"></span>
                    <div id="ccImgPreviewWrap" style="margin-top:10px;display:none;">
                        <img id="ccImgPreview" src="" alt="Önizleme"
                             style="max-height:120px;max-width:100%;border-radius:10px;border:1px solid var(--border);object-fit:contain;background:var(--bg-dark3);padding:6px;" />
                    </div>
                </div>

            </div>
            <div class="cc-actions">
                <a asp-area="Admin" asp-controller="Category" asp-action="CategoryList" class="btn-outline">✕ Vazgeç</a>
                <button type="submit" class="btn-accent">💾 Kategoriyi Güncelle</button>
            </div>

        </form>
    </div>

</div>

<script>
    function ccPreviewImage(url) {
        var wrap = document.getElementById('ccImgPreviewWrap');
        var img  = document.getElementById('ccImgPreview');
        if (url && url.trim()) {
            img.src = url.trim();
            wrap.style.display = 'block';
        } else {
            wrap.style.display = 'none';
        }
    }

    window.addEventListener('load', function () {
        var existing = document.getElementById('CategoryImage').value;
        if (existing) ccPreviewImage(existing);
    });
</script>

@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
